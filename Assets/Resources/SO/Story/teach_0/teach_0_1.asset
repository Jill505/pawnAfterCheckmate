  - "\u54C7!!?! \u9019\u662F\u54EA\uFF1F\u9019\u4E9B\u4EBA\u662F\u4EC0\u9EBC\uFF1F"
  - "Comm/SetSpeaker/\u9053\u58EB"
  - "\u9019\u5152\u4E43\u662F\u4EBA\u7684\u5922\u4E2D\uFF0C\u4F60\u773C\u524D\u7684\u4FBF\u662F\u96DC\u5FF5"
  - "\u96DC\u5FF5\u6709\u8457\u4E0D\u540C\u7684\u5F62\u5F0F\u8207\u80FD\u529B"
  - "\u800C\u6BCF\u56DE\u5408\uFF0C\u65B0\u7684\u96DC\u5FF5\u90FD\u6703\u66F4\u751F\u51FA\u4F86"
  - "\u8981\u662F\u653E\u8457\u9019\u4E9B\u96DC\u5FF5\u4E0D\u7BA1\uFF0C\u4ED6\u5011\u6BCF\u4E00\u56DE\u5408\u7684\u80FD\u529B\u90FD\u6703\u518D\u6210\u9577\uFF01"
  - "\u552F\u6709\u65AC\u6BBA\u300C\u7665\u7D50\u300D\u6575\u4EBA\u624D\u80FD\u7834\u9664\u9019\u4E00\u5207"
  - "\u4F60\u525B\u4F86\u5230\u7389\u73EE\u4E2D\uFF0C\u53EF\u80FD\u9084\u4E0D\u592A\u719F\u6089\u74B0\u5883"
  - "\u60F3\u50CF\u4F60\u9762\u524D\u6709\u500B\u9375\u76E4\u548C\u6ED1\u9F20"
  - "\u53EA\u8981 \u5DE6\u9375 \u9EDE\u64CA\u300E\u4F60\u300F\uFF0C\u5C31\u53EF\u4EE5\u770B\u898B\u79FB\u52D5\u7684\u7BC4\u570D"
  - "\u79FB\u52D5\u5230\u96DC\u5FF5\u4E0A\uFF0C\u4FBF\u53EF\u4EE5\u64CA\u6BBA\u5C0D\u65B9"
  - "\u800C\u64CA\u6BBA\u96DC\u5FF5\uFF0C\u5C31\u53EF\u4EE5\u8907\u88FD\u653B\u64CA\u7BC4\u570D\u8207\u4E00\u5B9A\u7684\u80FD\u529B"
  - "\u5728\u6642\u9650\u5167\u5B8C\u6210\u5DE6\u4E0B\u89D2\u7684\u3010\u76EE\u6A19\u3011\u5427\uFF01"
